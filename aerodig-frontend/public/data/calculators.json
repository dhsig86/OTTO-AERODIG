  {
    "id": "myer-cotton-calc",
    "slug": "myer-cotton-calc",
    "title_pt": "Calculadora Myer-Cotton (estenose subglotica)",
    "title_en": "Myer-Cotton Calculator",
    "audience": "pediatric",
    "domain": "airway",
    "summary": "Estima grau de estenose subglotica a partir do diametro interno do tubo endotraqueal sem cuff que passa sem vazamento, comparado ao esperado para a faixa etaria. Grau I ate 50%, II 51-70%, III 71-99%, IV sem lumen detectavel.",
    "confidence": "high",
    "confidence_rationale": "Sistema de graduacao consagrado por Myer, O'Connor e Cotton (Ann Otol Rhinol Laryngol 1994).",
    "inputs": [
      {
        "key": "patient_age_band",
        "label": "Faixa etaria",
        "input_type": "select",
        "options": [
          "Neonato",
          "Lactente (<6m)",
          "Lactente (6-12m)",
          "Toddler (1-3a)",
          "Pre-escolar",
          "Escolar",
          "Adolescente"
        ],
        "notes": "Determina o tubo endotraqueal esperado para a idade."
      },
      {
        "key": "et_tube_passing",
        "label": "Maior tubo OT sem cuff que passa sem vazamento (mm DI)",
        "input_type": "number",
        "unit": "mm",
        "notes": "Use o maior tamanho que passa com pressao de ventilacao normal."
      }
    ],
    "outputs": [
      {
        "key": "stenosis_grade",
        "label": "Grau de estenose (Myer-Cotton)"
      },
      {
        "key": "lumen_reduction_pct",
        "label": "Reducao da area transversal estimada",
        "unit": "%"
      }
    ],
    "formula_hint": "Reduction% = [1 - (tubo_observado / tubo_esperado)^2] x 100. Grau I <=50%; II 51-70%; III 71-99%; IV sem lumen.",
    "reference_table": [
      {
        "age_band": "Neonato",
        "expected_id_mm": 3.0,
        "expected_id_range": "2.5-3.5"
      },
      {
        "age_band": "Lactente (<6m)",
        "expected_id_mm": 3.5,
        "expected_id_range": "3.0-3.5"
      },
      {
        "age_band": "Lactente (6-12m)",
        "expected_id_mm": 4.0,
        "expected_id_range": "3.5-4.0"
      },
      {
        "age_band": "Toddler (1-3a)",
        "expected_id_mm": 4.5,
        "expected_id_range": "4.0-4.5"
      },
      {
        "age_band": "Pre-escolar",
        "expected_id_mm": 5.0,
        "expected_id_range": "4.5-5.5"
      },
      {
        "age_band": "Escolar",
        "expected_id_mm": 6.0,
        "expected_id_range": "5.5-6.5"
      },
      {
        "age_band": "Adolescente",
        "expected_id_mm": 7.0,
        "expected_id_range": "6.5-7.5"
      }
    ],
    "notes_ptbr": "Use sempre tubo sem cuff. Variações de 0.5 mm podem mudar o grau. Confirme com broncoscopia rigida.",
    "sources": [
      {
        "title": "Proposed grading system for subglottic stenosis based on endotracheal tube sizes",
        "authors": "Myer CM, O'Connor DM, Cotton RT",
        "journal": "Ann Otol Rhinol Laryngol",
        "year": 1994,
        "pmid": "8109626",
        "source_type": "primary"
      },
      {
        "title": "Pediatric Airway Surgery",
        "authors": "Monnier P",
        "source_type": "textbook",
        "year": 2011
      }
    ]
  },
  {
    "id": "pedi-eat-10-calc",
    "slug": "pedi-eat-10-calc",
    "title_pt": "PEDI-EAT-10 (calculadora)",
    "title_en": "PEDI-EAT-10 calculator",
    "audience": "pediatric",
    "domain": "swallowing",
    "summary": "Versao interativa do questionario PEDI-EAT-10. 10 itens de 0 a 4. Soma maior que 3 sugere sintomatologia significativa de disfagia.",
    "confidence": "high",
    "confidence_rationale": "Validado em multiplos idiomas; traducao PT-BR disponivel.",
    "inputs": [
      {
        "key": "i1",
        "label": "1 - Engasga durante refeicoes",
        "input_type": "number",
        "unit": "0-4"
      },
      {
        "key": "i2",
        "label": "2 - Tosse durante ou apos alimentacao",
        "input_type": "number",
        "unit": "0-4"
      },
      {
        "key": "i3",
        "label": "3 - Voz molhada apos deglutir",
        "input_type": "number",
        "unit": "0-4"
      },
      {
        "key": "i4",
        "label": "4 - Demora excessiva nas refeicoes",
        "input_type": "number",
        "unit": "0-4"
      },
      {
        "key": "i5",
        "label": "5 - Recusa alimentar",
        "input_type": "number",
        "unit": "0-4"
      },
      {
        "key": "i6",
        "label": "6 - Pneumonia recorrente",
        "input_type": "number",
        "unit": "0-4"
      },
      {
        "key": "i7",
        "label": "7 - Perda ou falha de ganho ponderal",
        "input_type": "number",
        "unit": "0-4"
      },
      {
        "key": "i8",
        "label": "8 - Residuo oral pos-degluticao",
        "input_type": "number",
        "unit": "0-4"
      },
      {
        "key": "i9",
        "label": "9 - Sialorreia importante",
        "input_type": "number",
        "unit": "0-4"
      },
      {
        "key": "i10",
        "label": "10 - Estresse familiar com alimentacao",
        "input_type": "number",
        "unit": "0-4"
      }
    ],
    "outputs": [
      {
        "key": "total",
        "label": "Pontuacao total",
        "unit": "pontos"
      },
      {
        "key": "interpretation",
        "label": "Interpretacao"
      }
    ],
    "formula_hint": "Soma simples i1..i10. Interpretacao: 0-3 normal/limitrofe; maior que 3 = sintomatologia significativa.",
    "sources": [
      {
        "title": "Pediatric Eating Assessment Tool (PEDI-EAT-10)",
        "authors": "Serel-Arslan S, Demir N, Karaduman AA",
