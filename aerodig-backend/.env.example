# Firebase Admin (service account JSON em string única, escapado)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Frontend (Vercel) e dev local
FRONTEND_URL=http://localhost:5176

# LLM para resumos PT-BR de news
DEEPSEEK_API_KEY=
# ou GROQ_API_KEY=

# PubMed E-utilities (opcional, mas aumenta rate limit)
PUBMED_API_KEY=
PUBMED_EMAIL=dr.dhsig@gmail.com
PUBMED_TOOL=otto-aerodig

# Token secreto para autorizar /api/jobs/pubmed-daily
NEWS_CRON_SECRET=

# Toggle para usar seed local em vez de Firestore (útil em dev offline)
USE_LOCAL_SEEDS=true
